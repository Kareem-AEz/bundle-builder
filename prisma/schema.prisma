// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Category {
  id           String    @id // "cameras"
  step         Int
  stepTitle    String
  singleSelect Boolean   @default(false)
  reviewLabel  String
  reviewOrder  Int
  products     Product[]
}

model Product {
  id         String    @id
  title      String
  tagline    String
  image      String?
  price      Int // cents, never float
  compareAt  Int?
  unit       String? // "month" | null — SQLite has no enums
  required   Boolean   @default(false)
  max        Int?
  sortOrder  Int // array position in catalog.ts; rows come back unordered without it
  categoryId String
  category   Category  @relation(fields: [categoryId], references: [id])
  variants   Variant[]
}

model Variant {
  id        String  @id // the quantity key — must match catalog.ts byte for byte
  label     String
  swatch    String
  sortOrder Int
  productId String
  product   Product @relation(fields: [productId], references: [id])
}
