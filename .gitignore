# =============================================================================
# Git Ignore Configuration
# =============================================================================
# See https://help.github.com/articles/ignoring-files/ for more information

# =============================================================================
# Dependencies
# =============================================================================
/node_modules
/.pnp
.pnp.*

# Yarn
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# =============================================================================
# Environment Variables & Secrets
# =============================================================================
# Never commit files containing sensitive credentials
.env
.env.local
.env.*.local

# Keep the example template for documentation
!.env.example

# =============================================================================
# Local-only briefs, notes & design reference (NEVER commit — repo is public)
# =============================================================================
*.local.md
*.local/

# Inherited boilerplate docs — not part of the shipped project
/docs/

# =============================================================================
# Next.js & Build Output
# =============================================================================
# Generated directories
/.next/
/out/
/build/

# Build artifacts
*.tsbuildinfo
next-env.d.ts

# =============================================================================
# Generated Code
# =============================================================================
# Prisma generated client (should be committed if checking in migrations)
# /src/generated/prisma

# =============================================================================
# Test & Coverage
# =============================================================================
/coverage
*.lcov

# =============================================================================
# IDE & Editor Files
# =============================================================================
# VS Code
.vscode/

# IDE-specific files
.idea/
.DS_Store
*.swp
*.swo
*~

# =============================================================================
# AI Agent Config
# =============================================================================
# Agentic tooling stays local — not part of the shipped project
.agents/
.claude/
.cursor/
.cursorignore
.mcp.json
AGENTS.md
CLAUDE.md

# =============================================================================
# Logs & Debug
# =============================================================================
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
lerna-debug.log*

# =============================================================================
# OS-Specific Files
# =============================================================================
.DS_Store
Thumbs.db

# =============================================================================
# SSL/TLS Certificates (if any)
# =============================================================================
*.pem

# =============================================================================
# Vercel
# =============================================================================
.vercel

# =============================================================================
# Prisma
# =============================================================================
/src/generated