{
  "rules": {
    "maxSubjectLength": 50,
    "maxBulletLength": 72,
    "minBullets": 1,
    "timeout": 90000
  },
  "scopePatterns": [
    { "pattern": "src/features/([^/]+)/.*", "scope": "$1", "weight": 10 },
    { "pattern": "src/app/([^/]+)/.*", "scope": "$1", "weight": 9 },
    { "pattern": "src/components/([^/]+)/.*", "scope": "$1", "weight": 8 },
    { "pattern": "src/lib/([^/]+)/.*", "scope": "$1", "weight": 8 },
    { "pattern": "prisma/.*", "scope": "db", "weight": 5 },
    { "pattern": "src/([^/]+).*", "scope": "$1", "weight": 6 }
  ],
  "exclude": [".next/", "out/", "build/", "src/generated/"]
}
