# ──────────────────────────────────────────────────────────────────────────────
# Environment Configuration
# The app runs with no .env at all — every variable it reads has a default.
# Copy to .env only to override one, or to set up the local tooling below.
# Never commit .env.
# ──────────────────────────────────────────────────────────────────────────────

# ── App ───────────────────────────────────────────────────────────────────────
# Brand identity (name, description) lives in src/config/site.ts — it's the same
# across every environment, so it isn't an env var.

# Required — canonical base URL (per-environment: localhost in dev, real domain in prod)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite as a local file. No server, no Docker, no accounts — clone, install,
# `npm run db:migrate && npm run db:seed`, and you have a database.

# Optional — defaults to file:./prisma/dev.db. Path is relative to the project root.
DATABASE_URL="file:./prisma/dev.db"

# ──────────────────────────────────────────────────────────────────────────────
# Local tooling — dev only. Never commit real values.
# ──────────────────────────────────────────────────────────────────────────────

# AI commit generator (convit) — powers `npm run commit`.
# Pick one provider block, uncomment it, and fill in the values.

# LM Studio (local, no API key needed)
# CONVIT_URL="http://localhost:1234/v1"
# CONVIT_KEY=""
# CONVIT_MODEL=""

# Cloud provider (OpenAI, xAI, Anthropic, Vercel AI Gateway, ...)
# CONVIT_URL="https://ai-gateway.vercel.sh/v1"
# CONVIT_KEY=""
# CONVIT_MODEL=""
# Cost per 1M tokens (USD), for spend reporting
# CONVIT_INPUT_COST="0.15"
# CONVIT_OUTPUT_COST="0.60"
# Request timeout (ms)
# CONVIT_TIMEOUT="60000"