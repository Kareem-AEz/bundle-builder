# ──────────────────────────────────────────────────────────────────────────────
# Environment Configuration
# Copy to .env and fill in your values. Never commit .env.
# ──────────────────────────────────────────────────────────────────────────────

# ── App ───────────────────────────────────────────────────────────────────────
# Brand identity (name, description) lives in src/config/site.ts — it's the same
# across every environment, so it isn't an env var.

# Required — canonical base URL (per-environment: localhost in dev, real domain in prod)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ── Database ──────────────────────────────────────────────────────────────────

# Required — direct connection for Prisma migrations (db:generate / db:migrate)
DATABASE_DIRECT_URL="postgresql://postgres:password@localhost:5432/localdb"

# Required — pooled connection for app runtime queries
# Local dev: same as above. Hosted (Neon, Supabase): use the pooler URL (port 6543)
DATABASE_POOLED_URL="postgresql://postgres:password@localhost:5432/localdb"
